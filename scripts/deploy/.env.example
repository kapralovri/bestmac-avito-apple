# ─────────────────────────────────────────────────────────────────────────────
# BestMac — секреты для сканера и бота переговоров.
# Скопируйте в КОРЕНЬ репозитория как .env и заполните:
#     cp scripts/deploy/.env.example .env  &&  nano .env
# Файл .env в git не попадает (он в .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Куда сканер шлёт уведомления о сделках (твой текущий релей/бот — как сейчас).
TELEGRAM_NOTIFY_URL=

# Токен ТОГО ЖЕ бота для двусторонней работы (переговоры).
# Берётся у @BotFather → твой бот → "API Token", или из настройки релея.
TELEGRAM_BOT_TOKEN=

# (необязательно) Жёстко зафиксировать владельца. Пусто — бот запомнит того,
# кто первым напишет /start.
OWNER_CHAT_ID=

# ── Обход капчи Avito ────────────────────────────────────────────────────────
RUCAPTCHA_API_KEY=

# ── DeepSeek (co-pilot + переговорщик) ───────────────────────────────────────
DEEPSEEK_API_KEY=
# По умолчанию deepseek-chat. Меняй только если у тебя другой эндпоинт/модель.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── (необязательно) Прокси для Avito ─────────────────────────────────────────
PROXY_URL=
CHANGE_IP_URL=

# ── (необязательно) Тюнинг детектора ниже-рынка ──────────────────────────────
# Дефолты разумные; раскомментируй, только если хочешь подправить.
# MIN_MARGIN=0.10
# MIN_COMPS=6
# SCAM_FLOOR=0.55
# SCAN_PAGES_PER_FAMILY=3
# MIN_NOTIFY_SCORE=75
# STALE_PRICES_HOURS=36
